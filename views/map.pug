extends layout

block content
  link(rel='stylesheet', href='/css/sweetalert2.11.26.23.min.css')
  script(src='/js/sweetalert2.all.11.26.23.min.js', type='text/javascript')
  script(src='/js/validator.13.15.26.min.js', type='text/javascript')

  style
    include ../public/css/map.css

  style.
    :root {
      --color-unvisited:          !{mapColors.unvisited};
      --color-unvisited-hover:    !{mapColors.unvisitedHover};
      --color-visited:            !{mapColors.visited};
      --color-visited-hover:      !{mapColors.visitedHover};
      --color-bg:                 !{mapColors.bg};
      --color-continent-eu:       !{mapColors.continents.eu.color};
      --color-continent-eu-hover: !{mapColors.continents.eu.hover};
      --color-continent-as:       !{mapColors.continents.as.color};
      --color-continent-as-hover: !{mapColors.continents.as.hover};
      --color-continent-af:       !{mapColors.continents.af.color};
      --color-continent-af-hover: !{mapColors.continents.af.hover};
      --color-continent-na:       !{mapColors.continents.na.color};
      --color-continent-na-hover: !{mapColors.continents.na.hover};
      --color-continent-sa:       !{mapColors.continents.sa.color};
      --color-continent-sa-hover: !{mapColors.continents.sa.hover};
      --color-continent-oc:       !{mapColors.continents.oc.color};
      --color-continent-oc-hover: !{mapColors.continents.oc.hover};
    }

  style.
    body { overflow: hidden; }
    #map-container {
      width: 100%;
      height: calc(100vh - 60px);
      margin: 0;
      position: relative;
    }
    #svg-container {
      width: 100%;
      height: 100%;
    }
    #zoom-controls {
      position: absolute;
      top: 12px;
      left: 12px;
      z-index: 100;
      float: none;
    }
    #external-controls {
      position: absolute;
      top: 12px;
      right: 12px;
      z-index: 100;
      margin: 0;
      width: auto;
      display: flex;
      gap: 8px;
      align-items: center;
    }

  script.
    var mapId = !{JSON.stringify(mapId)};
    var mapType = !{JSON.stringify(mapType)};
    var validTypes = !{JSON.stringify(validTypes)};
    var objectList = !{JSON.stringify(objectList)};
    var scratchedObjects = !{JSON.stringify(scratchedObjects)};
    var disabledCodes = !{JSON.stringify(disabledCodes)};
    var enableShare = !{JSON.stringify(enableShare)};
    var mapColors = !{JSON.stringify(mapColors)};

  div#map-container
    div#zoom-controls
      button#zoom-fullscreen(type='button', onclick='fullscreenView()') Fullscreen
      button#zoom-reset(type='button', onclick='resetView()') Reset
      button#zoom-in(type='button', onclick='zoomIn()') +
      button#zoom-out(type='button', onclick='zoomOut()') -

    div#external-controls
      button#color-btn(type='button', onclick='openColorSettings()') 🎨
      if enableShare
        button#share-button(type='button', onclick='copyViewLink()')
          span#share-text= 'Share '
          include ../public/images/share.svg

    if mapType == 'world'
      div#svg-container(
        data-zoom-on-wheel="zoom-amount: 0.003; min-scale: 1; max-scale: 8;",
        data-pan-on-drag="button: left;"
      )
        !=mapSVG
    else
      div#svg-container(
        data-zoom-on-wheel="zoom-amount: 0.003; min-scale: 1; max-scale: 2;",
        data-pan-on-drag="button: left;"
      )
        !=mapSVG

  script(src='/js/scratch.js', type='text/javascript')
  script(src='/js/svg-pan-zoom-container.0.6.1.min.js', type='text/javascript')
  script(src='/js/svg_controls.js', type='text/javascript')

  if enableShare
    script.
      function copyViewLink() {
        var currentUrl = window.location.href;
        var viewUrl = currentUrl.replace("/map/", "/view/");
        navigator.clipboard.writeText(viewUrl);
        alert(`View-only URL Copied!\n${viewUrl}`);
      }

  script.
    const COLOR_DEFAULTS = {
      unvisited: '#c9982a', visited: '#3daa6a', bg: '#0a0a0a',
      continentEu: '#4a80d4', continentAs: '#d4703a', continentAf: '#c94848',
      continentNa: '#8b5cd4', continentSa: '#2eb898', continentOc: '#2aacbc',
    };

    function lightenHex(hex, amount) {
      amount = amount || 0.15;
      var r = parseInt(hex.slice(1, 3), 16);
      var g = parseInt(hex.slice(3, 5), 16);
      var b = parseInt(hex.slice(5, 7), 16);
      return '#' + [r, g, b].map(function(c) {
        return Math.min(255, Math.round(c + (255 - c) * amount)).toString(16).padStart(2, '0');
      }).join('');
    }

    function applyColors(c) {
      var root = document.documentElement;
      root.style.setProperty('--color-unvisited',          c.unvisited);
      root.style.setProperty('--color-unvisited-hover',    lightenHex(c.unvisited));
      root.style.setProperty('--color-visited',            c.visited);
      root.style.setProperty('--color-visited-hover',      lightenHex(c.visited));
      root.style.setProperty('--color-bg',                 c.bg);
      root.style.setProperty('--color-continent-eu',       c.continentEu);
      root.style.setProperty('--color-continent-eu-hover', lightenHex(c.continentEu));
      root.style.setProperty('--color-continent-as',       c.continentAs);
      root.style.setProperty('--color-continent-as-hover', lightenHex(c.continentAs));
      root.style.setProperty('--color-continent-af',       c.continentAf);
      root.style.setProperty('--color-continent-af-hover', lightenHex(c.continentAf));
      root.style.setProperty('--color-continent-na',       c.continentNa);
      root.style.setProperty('--color-continent-na-hover', lightenHex(c.continentNa));
      root.style.setProperty('--color-continent-sa',       c.continentSa);
      root.style.setProperty('--color-continent-sa-hover', lightenHex(c.continentSa));
      root.style.setProperty('--color-continent-oc',       c.continentOc);
      root.style.setProperty('--color-continent-oc-hover', lightenHex(c.continentOc));
    }

    function readCurrentColors() {
      return {
        unvisited:   document.getElementById('c-unvisited').value,
        visited:     document.getElementById('c-visited').value,
        bg:          document.getElementById('c-bg').value,
        continentEu: document.getElementById('c-eu').value,
        continentAs: document.getElementById('c-as').value,
        continentAf: document.getElementById('c-af').value,
        continentNa: document.getElementById('c-na').value,
        continentSa: document.getElementById('c-sa').value,
        continentOc: document.getElementById('c-oc').value,
      };
    }

    function savedColors() {
      return {
        unvisited:   mapColors.unvisited,
        visited:     mapColors.visited,
        bg:          mapColors.bg,
        continentEu: mapColors.continents.eu.color,
        continentAs: mapColors.continents.as.color,
        continentAf: mapColors.continents.af.color,
        continentNa: mapColors.continents.na.color,
        continentSa: mapColors.continents.sa.color,
        continentOc: mapColors.continents.oc.color,
      };
    }

    async function openColorSettings() {
      var sc = savedColors();
      var result = await Swal.fire({
        title: 'Map Colors',
        width: 520,
        html:
          '<div style="text-align:left;padding:0 4px">' +
          section('General') +
          colorRow('Unvisited',       'c-unvisited', sc.unvisited) +
          colorRow('Visited (non-world)', 'c-visited', sc.visited) +
          colorRow('Background / ocean', 'c-bg',      sc.bg) +
          section('World map — visited by continent') +
          '<div style="display:grid;grid-template-columns:1fr 1fr;gap:6px 16px">' +
          colorRow('Europe',        'c-eu', sc.continentEu) +
          colorRow('Asia',          'c-as', sc.continentAs) +
          colorRow('Africa',        'c-af', sc.continentAf) +
          colorRow('North America', 'c-na', sc.continentNa) +
          colorRow('South America', 'c-sa', sc.continentSa) +
          colorRow('Oceania',       'c-oc', sc.continentOc) +
          '</div></div>',
        showConfirmButton: true,
        showDenyButton: true,
        confirmButtonText: 'Save',
        denyButtonText: 'Cancel',
        confirmButtonColor: '#4d9e1b',
        denyButtonColor: '#aaa',
        didOpen: function() {
          var ids = ['c-unvisited','c-visited','c-bg','c-eu','c-as','c-af','c-na','c-sa','c-oc'];
          ids.forEach(function(id) {
            document.getElementById(id).addEventListener('input', function() {
              applyColors(readCurrentColors());
            });
          });
        },
        preConfirm: readCurrentColors,
      });

      if (!result.isConfirmed) {
        applyColors(sc);
        return;
      }

      var c = result.value;
      var payload = {
        unvisitedColor: c.unvisited   === COLOR_DEFAULTS.unvisited   ? null : c.unvisited,
        visitedColor:   c.visited     === COLOR_DEFAULTS.visited      ? null : c.visited,
        bgColor:        c.bg          === COLOR_DEFAULTS.bg           ? null : c.bg,
        continentEu:    c.continentEu === COLOR_DEFAULTS.continentEu ? null : c.continentEu,
        continentAs:    c.continentAs === COLOR_DEFAULTS.continentAs ? null : c.continentAs,
        continentAf:    c.continentAf === COLOR_DEFAULTS.continentAf ? null : c.continentAf,
        continentNa:    c.continentNa === COLOR_DEFAULTS.continentNa ? null : c.continentNa,
        continentSa:    c.continentSa === COLOR_DEFAULTS.continentSa ? null : c.continentSa,
        continentOc:    c.continentOc === COLOR_DEFAULTS.continentOc ? null : c.continentOc,
      };

      var resp = await fetch('/maps/' + mapId + '/settings', {
        method: 'PUT',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(payload),
      });
      var data = await resp.json();
      if (data.status !== 200) {
        Toast.fire({ icon: 'error', title: data.message });
        applyColors(sc);
        return;
      }

      mapColors.unvisited        = c.unvisited;
      mapColors.visited          = c.visited;
      mapColors.bg               = c.bg;
      mapColors.continents.eu    = { color: c.continentEu, hover: lightenHex(c.continentEu) };
      mapColors.continents.as    = { color: c.continentAs, hover: lightenHex(c.continentAs) };
      mapColors.continents.af    = { color: c.continentAf, hover: lightenHex(c.continentAf) };
      mapColors.continents.na    = { color: c.continentNa, hover: lightenHex(c.continentNa) };
      mapColors.continents.sa    = { color: c.continentSa, hover: lightenHex(c.continentSa) };
      mapColors.continents.oc    = { color: c.continentOc, hover: lightenHex(c.continentOc) };
      applyColors(c);
      Toast.fire({ icon: 'success', title: 'Colors saved!' });
    }

    function section(title) {
      return '<div style="font-size:11px;font-weight:700;text-transform:uppercase;letter-spacing:.5px;color:#aaa;margin:14px 0 8px">' + title + '</div>';
    }

    function colorRow(label, id, value) {
      return '<div style="display:flex;align-items:center;margin-bottom:8px;gap:8px">' +
        '<input type="color" id="' + id + '" value="' + value + '" style="width:36px;height:28px;cursor:pointer;border:1px solid #ddd;border-radius:4px;padding:2px;flex-shrink:0">' +
        '<label for="' + id + '" style="font-size:13px;color:#555;cursor:pointer">' + label + '</label>' +
        '</div>';
    }
