extends layout

block content
  link(rel='stylesheet', href='/css/sweetalert2.11.26.23.min.css')
  script(src='/js/sweetalert2.all.11.26.23.min.js', type='text/javascript')
  script(src='/js/validator.13.15.26.min.js', type='text/javascript')

  style
    include ../public/css/map.css

  style.
    :root {
      --color-unvisited:       !{mapColors.unvisited};
      --color-unvisited-hover: !{mapColors.unvisitedHover};
      --color-visited:         !{mapColors.visited};
      --color-visited-hover:   !{mapColors.visitedHover};
      --color-bg:              !{mapColors.bg};
    }

  if mapColors.customVisited
    style.
      .entities g.scratched path:not(.label-connector):not(.label-text),
      .entities g.scratched:hover path:not(.label-connector):not(.label-text),
      .entities g.scratched path:hover:not(.label-connector):not(.label-text) { fill: var(--color-visited) !important; }
      .entities g.scratched .label-box,
      .entities g.scratched:hover > .label-box { fill: var(--color-visited) !important; }

  style.
    body { overflow: hidden; }
    #map-container {
      width: 100%;
      height: calc(100vh - 60px);
      margin: 0;
      position: relative;
    }
    #svg-container {
      width: 100%;
      height: 100%;
    }
    #zoom-controls {
      position: absolute;
      top: 12px;
      left: 12px;
      z-index: 100;
      float: none;
    }
    #external-controls {
      position: absolute;
      top: 12px;
      right: 12px;
      z-index: 100;
      margin: 0;
      width: auto;
      display: flex;
      gap: 8px;
      align-items: center;
    }

  script.
    var mapId = !{JSON.stringify(mapId)};
    var mapType = !{JSON.stringify(mapType)};
    var validTypes = !{JSON.stringify(validTypes)};
    var objectList = !{JSON.stringify(objectList)};
    var scratchedObjects = !{JSON.stringify(scratchedObjects)};
    var disabledCodes = !{JSON.stringify(disabledCodes)};
    var enableShare = !{JSON.stringify(enableShare)};
    var mapColors = !{JSON.stringify(mapColors)};

  div#map-container
    div#zoom-controls
      button#zoom-fullscreen(type='button', onclick='fullscreenView()') Fullscreen
      button#zoom-reset(type='button', onclick='resetView()') Reset
      button#zoom-in(type='button', onclick='zoomIn()') +
      button#zoom-out(type='button', onclick='zoomOut()') -

    div#external-controls
      button#color-btn(type='button', onclick='openColorSettings()') 🎨
      if enableShare
        button#share-button(type='button', onclick='copyViewLink()')
          span#share-text= 'Share '
          include ../public/images/share.svg

    if mapType == 'world'
      div#svg-container(
        data-zoom-on-wheel="zoom-amount: 0.003; min-scale: 1; max-scale: 8;",
        data-pan-on-drag="button: left;"
      )
        !=mapSVG
    else
      div#svg-container(
        data-zoom-on-wheel="zoom-amount: 0.003; min-scale: 1; max-scale: 2;",
        data-pan-on-drag="button: left;"
      )
        !=mapSVG

  script(src='/js/scratch.js', type='text/javascript')
  script(src='/js/svg-pan-zoom-container.0.6.1.min.js', type='text/javascript')
  script(src='/js/svg_controls.js', type='text/javascript')

  if enableShare
    script.
      function copyViewLink() {
        var currentUrl = window.location.href;
        var viewUrl = currentUrl.replace("/map/", "/view/");
        navigator.clipboard.writeText(viewUrl);
        alert(`View-only URL Copied!\n${viewUrl}`);
      }

  script.
    const DEFAULT_MAP_COLORS = { unvisited: '#c9982a', visited: '#3daa6a', bg: '#0a0a0a' };

    function lightenHex(hex, amount) {
      amount = amount || 0.15;
      var r = parseInt(hex.slice(1, 3), 16);
      var g = parseInt(hex.slice(3, 5), 16);
      var b = parseInt(hex.slice(5, 7), 16);
      return '#' + [r, g, b].map(function(c) {
        return Math.min(255, Math.round(c + (255 - c) * amount)).toString(16).padStart(2, '0');
      }).join('');
    }

    function applyColors(uv, v, bg) {
      var root = document.documentElement;
      root.style.setProperty('--color-unvisited',       uv);
      root.style.setProperty('--color-unvisited-hover', lightenHex(uv));
      root.style.setProperty('--color-visited',         v);
      root.style.setProperty('--color-visited-hover',   lightenHex(v));
      root.style.setProperty('--color-bg',              bg);

      var override = document.getElementById('map-color-override');
      if (v !== DEFAULT_MAP_COLORS.visited) {
        if (!override) {
          override = document.createElement('style');
          override.id = 'map-color-override';
          document.head.appendChild(override);
        }
        override.textContent =
          '.entities g.scratched path:not(.label-connector):not(.label-text),' +
          '.entities g.scratched:hover path:not(.label-connector):not(.label-text),' +
          '.entities g.scratched path:hover:not(.label-connector):not(.label-text){fill:var(--color-visited)!important}' +
          '.entities g.scratched .label-box,' +
          '.entities g.scratched:hover > .label-box{fill:var(--color-visited)!important}';
      } else if (override) {
        override.remove();
      }
    }

    async function openColorSettings() {
      var result = await Swal.fire({
        title: 'Map Colors',
        html:
          '<div style="text-align:left;padding:0 4px">' +
            colorRow('Unvisited territories', 'c-unvisited', mapColors.unvisited) +
            colorRow('Visited territories', 'c-visited', mapColors.visited,
              mapColors.visited !== DEFAULT_MAP_COLORS.visited
                ? '<span style="font-size:11px;color:#aaa;margin-left:8px">Overrides continent colors on world map</span>'
                : '<span style="font-size:11px;color:#aaa;margin-left:8px">Overrides continent colors on world map</span>') +
            colorRow('Background / ocean', 'c-bg', mapColors.bg) +
          '</div>',
        showConfirmButton: true,
        showDenyButton: true,
        confirmButtonText: 'Save',
        denyButtonText: 'Cancel',
        confirmButtonColor: '#4d9e1b',
        denyButtonColor: '#aaa',
        didOpen: function() {
          document.getElementById('c-unvisited').addEventListener('input', function() { applyColors(this.value, document.getElementById('c-visited').value, document.getElementById('c-bg').value); });
          document.getElementById('c-visited').addEventListener('input',   function() { applyColors(document.getElementById('c-unvisited').value, this.value, document.getElementById('c-bg').value); });
          document.getElementById('c-bg').addEventListener('input',        function() { applyColors(document.getElementById('c-unvisited').value, document.getElementById('c-visited').value, this.value); });
        },
        preConfirm: function() {
          return {
            unvisitedColor: document.getElementById('c-unvisited').value,
            visitedColor:   document.getElementById('c-visited').value,
            bgColor:        document.getElementById('c-bg').value,
          };
        },
      });

      if (!result.isConfirmed) {
        applyColors(mapColors.unvisited, mapColors.visited, mapColors.bg);
        return;
      }

      var uv = result.value.unvisitedColor;
      var v  = result.value.visitedColor;
      var bg = result.value.bgColor;

      var resp = await fetch('/maps/' + mapId + '/settings', {
        method: 'PUT',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          unvisitedColor: uv === DEFAULT_MAP_COLORS.unvisited ? null : uv,
          visitedColor:   v  === DEFAULT_MAP_COLORS.visited   ? null : v,
          bgColor:        bg === DEFAULT_MAP_COLORS.bg         ? null : bg,
        }),
      });
      var data = await resp.json();
      if (data.status !== 200) {
        Toast.fire({ icon: 'error', title: data.message });
        applyColors(mapColors.unvisited, mapColors.visited, mapColors.bg);
        return;
      }

      mapColors.unvisited = uv;
      mapColors.visited   = v;
      mapColors.bg        = bg;
      applyColors(uv, v, bg);
      Toast.fire({ icon: 'success', title: 'Colors saved!' });
    }

    function colorRow(label, id, value, extra) {
      return '<div style="display:flex;align-items:center;margin-bottom:14px">' +
        '<label style="font-size:13px;color:#555;font-weight:600;width:180px;flex-shrink:0">' + label + '</label>' +
        '<input type="color" id="' + id + '" value="' + value + '" style="width:48px;height:32px;cursor:pointer;border:1px solid #ddd;border-radius:4px;padding:2px">' +
        (extra || '') +
        '</div>';
    }
